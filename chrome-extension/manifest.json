{
  "manifest_version": 3,
  "name": "Portfolio Review — injae",
  "version": "1.0",
  "description": "Deixe comentários visuais no portfolio para o Claude Code aplicar",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "http://localhost:5173/*",
    "https://portfolio-injae.vercel.app/*",
    "http://localhost:3001/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Portfolio Review"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "https://portfolio-injae.vercel.app/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
